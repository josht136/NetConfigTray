<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>NetConfigTray</AssemblyName>
    <RootNamespace>NetConfigTray</RootNamespace>
    <Version>1.0.0</Version>
    <Description>Quick view of active network interface IP addresses and Static/DHCP configuration</Description>
    <Company>NetConfigTray</Company>
    <Product>NetConfigTray</Product>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <UseAppHost>false</UseAppHost>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
  </PropertyGroup>

  <!-- Re-enable apphost (.exe) only when publishing a release build -->
  <PropertyGroup Condition="'$(PublishProtocol)' != '' or '$(RuntimeIdentifier)' != ''">
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="9.0.0" />
  </ItemGroup>

</Project>
